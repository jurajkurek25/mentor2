# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude) — claude-haiku-4-5-20251001 je najlacnejší model, s ktorým počíta cenotvorba
# predplatného v README.md (sekcia "Cenotvorba"); claude-sonnet-5 je kvalitnejšia, ale ~3x drahšia alternatíva
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-xxxxx
VOYAGE_MODEL=voyage-3

# Admin
ADMIN_PASSWORD=zmen-si-toto-heslo

# Server
PORT=3000
APP_BASE_URL=http://localhost:3000

# Prihlásenie (JWT cookie) — vygeneruj náhodný dlhý reťazec, napr.: openssl rand -hex 32
JWT_SECRET=zmen-si-toto-na-nahodny-dlhy-retazec

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth client ID, typ "Web application")
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Koľko bezplatných otázok dostane návštevník bez účtu, kým ho appka požiada o registráciu/predplatné
FREE_MESSAGE_LIMIT=5

# Stripe (predplatné za odpovedové tokeny) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# Price ID vytvorených Products v Stripe Dashboarde (Product catalog → +Add product → Recurring)
# — pozri README.md sekciu "Cenotvorba" pre odporúčané ceny/kvóty
STRIPE_PRICE_ZAKLAD=price_xxxxx
STRIPE_PRICE_PREMIUM=price_xxxxx
